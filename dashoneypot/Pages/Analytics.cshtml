@page
@using MongoDB.Bson
@using MongoDB.Driver
@inject IMongoCollection<BsonDocument> Collection
@{
    ViewData["Title"] = "Analiză Atacatori";

    var pipeline = new BsonDocument[]
    {
        new BsonDocument("$group", new BsonDocument {
            { "_id", "$src_ip" },
            { "total_attacks", new BsonDocument("$sum", 1) },
            { "types", new BsonDocument("$addToSet", "$type") },
            { "first_seen", new BsonDocument("$min", "$timestamp") },
            { "last_seen", new BsonDocument("$max", "$timestamp") }
        }),
        new BsonDocument("$sort", new BsonDocument("total_attacks", -1)) 
    };

    var analytics = await Collection.Aggregate<BsonDocument>(pipeline).ToListAsync();
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Behavioral profiling pentru atacatori dupa IP</h2>
        <a asp-page="./Index" class="btn btn-outline-secondary">← Înapoi la Dashboard</a>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Top atacatori</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>IP Atacator</th>
                            <th class="text-center">Nr. Încercări</th>
                            <th>Protocoale Vizate</th>
                            <th>Interval Activitate</th>
                            <th>Status Risc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stat in analytics)
                        {
                            var count = stat["total_attacks"].AsInt32;
                            <tr>
                                <td class="fw-bold text-primary">@stat["_id"]</td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-danger fs-6">@count</span>
                                </td>
                                <td>
                                    @foreach (var type in stat["types"].AsBsonArray) {
                                        <span class="badge bg-info text-dark me-1">@type</span>
                                    }
                                </td>
                                <td class="small">
                                    <strong>Prima dată:</strong> @stat["first_seen"]<br />
                                    <strong>Ultima dată:</strong> @stat["last_seen"]
                                </td>
                                <td>
                                    @if(count > 100) {
                                        <span class="badge bg-danger">Activitate crescută (pentru SSH: brute-force)</span>
                                    } else if (count > 20) {
                                        <span class="badge bg-warning text-dark">Scanare repetată</span>
                                    } else {
                                        <span class="badge bg-success">Activitate redusă (scouting/recunoaștere)</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>